DISCORD_WEBHOOK_URL=
CODEX_USAGE_URL=https://chatgpt.com/codex/cloud/settings/analytics#usage
CLAUDE_USAGE_URL=https://claude.ai/settings/usage
CHECK_INTERVAL_MINUTES=10
IDLE_MINUTES_BEFORE_SUMMARY=20
WEEKLY_FULL_REMINDER_HOURS=4
QUIET_HOURS_ENABLED=true
QUIET_HOURS_START=23
QUIET_HOURS_END=8
HEADLESS=true
LOG_LEVEL=info
# State/config/runtime files live under ~/Library/Application Support/Mongi
# and logs under ~/Library/Logs/Mongi regardless of where Mongi is launched.
# Leave STATE_FILE_PATH empty to use that standard location. Set an absolute
# path only to override. Relative values are migrated into the standard dir.
STATE_FILE_PATH=
BROWSER_CONNECTION_MODE=cdp
CHROME_CDP_URL=http://127.0.0.1:9222
CHROME_USER_DATA_DIR=$HOME/.mongi-chrome-profile



NOTIFY_RECOVERED_SHORT=true
NOTIFY_RECOVERED_WEEKLY=true
NOTIFY_SESSION_STOPPED=true
NOTIFY_WEEKLY_IDLE=true
NOTIFY_DIAGNOSTIC=true

MESSAGE_INTENSITY=normal
SESSION_IDLE_MINUTES=20
WEEKLY_IDLE_REMINDER_HOURS=4
DIAGNOSTIC_REMINDER_HOURS=6