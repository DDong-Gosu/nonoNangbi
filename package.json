{
  "name": "mongi-usage-coach",
  "version": "3.0.0-rc.1",
  "private": true,
  "description": "Personal Discord usage coach for Codex and Claude.",
  "main": "src/monitor.js",
  "scripts": {
    "test:discord": "node scripts/test-discord.js",
    "notify:start": "node scripts/notify-start.js",
    "test:state": "node scripts/test-state.js",
    "test:scenarios": "node scripts/test-scenarios.js",
    "login": "node scripts/login.js",
    "launcher:guide": "node scripts/launcher-guide.js",
    "start:chrome": "bash scripts/start-cdp-chrome.sh",
    "check:cdp": "node scripts/check-cdp-status.js",
    "launchd:install": "bash scripts/install-launchd.sh",
    "launchd:uninstall": "bash scripts/uninstall-launchd.sh",
    "launchd:status": "bash scripts/check-launchd-status.sh",
    "launchd:logs": "tail -n 100 -f logs/launchd-out.log logs/launchd-error.log",
    "monitor:run": "bash scripts/run-monitor.sh",
    "health": "node scripts/health-check.js",
    "logs:summary": "node scripts/summarize-launchd-logs.js",
    "daily:summary": "node scripts/daily-summary.js",
    "policy:check": "node scripts/policy-check.js",
    "status:json": "node scripts/status-json.js",
    "value:review": "node scripts/value-review.js",
    "verify:local": "bash scripts/verify-local-automation.sh",
    "verify:local:safe": "bash scripts/verify-local-safe.sh",
    "verify:usage-source": "node scripts/verify-usage-source.js",
    "build:monitor": "bash scripts/build-monitor-dist.sh",
    "build:app": "bash scripts/build-mongi-app.sh",
    "compile:app": "bash scripts/compile-and-run-mongi.sh",
    "package:app": "bash scripts/package-mongi-app.sh",
    "release:local": "npm run package:app",
    "open:app": "bash scripts/open-mongi-app.sh",
    "debug:page-text": "node scripts/debug-page-text.js",
    "debug:codex": "node scripts/debug-page-text.js codex",
    "debug:claude": "node scripts/debug-page-text.js claude",
    "chrome:command": "node scripts/print-chrome-command.js",
    "monitor": "node src/monitor.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "playwright": "^1.60.0"
  }
}
